<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Real Estate Api" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
      <div class="container">
        <a class="navbar-brand fw-bold" href="/">🏠 RE Explorer</a>
        <div class="navbar-nav ms-auto">
          <%= link_to "Search Listings", search_listings_path, class: "nav-link text-white" %>
          <%= link_to "Estimate Value", estimate_property_path, class: "nav-link text-white" %>
          <%= link_to "Market Trends", market_trends_path, class: "nav-link text-white" %>
        </div>
      </div>
    </nav>
    <% if content_for?(:full_width) %>
      <%= yield %>
    <% else %>
      <div class="container">
        <%= yield %>
      </div>
    <% end %>
  </body>
</html>
